{
  "governanceVersion": "1.1.0",
  "branch": {
    "prefixes": ["feature", "fix", "chore"],
    "slugRegex": "[a-z0-9._-]+"
  },
  "agents": [
    "agent:pm",
    "agent:backend",
    "agent:frontend",
    "agent:qa",
    "agent:release"
  ],
  "project": {
    "owner": "RidelHI",
    "number": 1,
    "statuses": {
      "preflight": ["In Progress"],
      "preflightAllowTodo": ["In Progress", "Todo"],
      "pullRequest": ["In Progress", "In Review"]
    }
  },
  "pullRequest": {
    "closingKeyword": "Closes",
    "requiredSection": "AI Self-Review Gate",
    "frameworkOptions": ["Angular way", "NestJS way"],
    "decisionOptions": ["Compliant", "Needs Changes"]
  },
  "quality": {
    "requiredCommands": ["pnpm lint", "pnpm test", "pnpm build"]
  },
  "orchestration": {
    "requirePmParentForExecutionAgents": true,
    "executionAgents": [
      "agent:backend",
      "agent:frontend",
      "agent:qa",
      "agent:release"
    ],
    "pmAgentLabel": "agent:pm",
    "parentPmField": "Parent PM",
    "executionOrderField": "Execution Order",
    "dependsOnField": "Depends on",
    "noneValue": "none",
    "requireExecutionOrderForExecutionAgents": true,
    "requireDependsOnFieldForExecutionAgents": true,
    "requireDependencyClosure": true,
    "requireParentToReferenceChildIssue": true
  },
  "aiOperatingBounds": {
    "mustFollowWorkflowOrder": true,
    "mustRespectIssueScope": true,
    "reasoningFreedom": "AI can plan and decide implementation logic using its own judgment as long as governance order and hard gates are respected."
  }
}
